{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@blockchain/common/*": ["packages/common/src/*"],
      "@blockchain/bank/*": ["packages/bank/src/*"],
      "@blockchain/miner/*": ["packages/miner/src/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true
  }
}
