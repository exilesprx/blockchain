# Docker
APP_VERSION=main

# .env
APP_PORT=3000
APP_NAME=blockchain
APP_ENV=dev

KAFKA_GROUP_ID=blockchain
KAFKA_CLIENT_ID=bckcid
KAFKA_HOST=broker
KAFKA_PORT=29092

# .env.eventstore
EVENTSTORE_CLUSTER_SIZE=1
EVENTSTORE_RUN_PROJECTIONS=All
EVENTSTORE_START_STANDARD_PROJECTIONS=true
