{
  "name": "blockchain",
  "description": "Blockchain implementation for fun.",
  "main": "app.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "app:bank": "pnpm --filter @blockchain/bank serve",
    "app:miner": "pnpm --filter @blockchain/miner serve",
    "build:bank": "pnpm --filter @blockchain/bank build",
    "build:miner": "pnpm --filter @blockchain/miner build",
    "debug:bank": "pnpm --filter @blockchain/bank debug",
    "debug:miner": "pnpm --filter @blockchain/miner debug"
  },
  "author": "Exilesprx <exiles.prx@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "globals": "^17.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
