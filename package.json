{
  "name": "blockchain",
  "private": true,
  "description": "Blockchain implementation for fun.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "serve:bank": "pnpm --filter @blockchain/bank serve",
    "serve:miner": "pnpm --filter @blockchain/miner serve",
    "watch:bank": "pnpm --filter @blockchain/bank watch",
    "watch:miner": "pnpm --filter @blockchain/miner watch",
    "typecheck:bank": "pnpm --filter @blockchain/bank typecheck",
    "typecheck:miner": "pnpm --filter @blockchain/miner typecheck",
    "debug:bank": "pnpm --filter @blockchain/bank debug",
    "debug:miner": "pnpm --filter @blockchain/miner debug",
    "build": "pnpm --filter @blockchain/common build && pnpm --filter bank build && pnpm --filter miner build",
    "build:bank": "pnpm --filter @blockchain/common build && pnpm --filter @blockchain/bank build",
    "build:miner": "pnpm --filter @blockchain/common build && pnpm --filter @blockchain/miner build",
    "build:common": "pnpm --filter @blockchain/common build",
    "setup": "pnpm --filter @blockchain/setup setup:kafka"
  },
  "author": "Exilesprx <exiles.prx@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "globals": "^17.7.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
